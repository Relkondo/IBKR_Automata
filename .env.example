TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# IBKR connection.  The port is chosen automatically based on the run
# mode: TWS port for interactive runs, Gateway port for -auto / cron.
# Defaults are derived from TRADING_MODE below.
IBKR_HOST=127.0.0.1
IBKR_CLIENT_ID=1
# IBKR_TWS_PORT=7496         # 7496=TWS live, 7497=TWS paper  (interactive)
# IBKR_GATEWAY_PORT=4001     # 4001=Gateway live, 4002=Gateway paper  (-auto)

# IB Gateway / IBC settings (only used by -auto mode to start gateway).
# See README for IBC installation instructions.
IBC_PATH=/opt/ibc
IBC_INI=~/ibc/config.ini
TWS_PATH=~/Applications
TWS_MAJOR_VRSN=10.44
TRADING_MODE=paper       # 'live' or 'paper'
GATEWAY_STARTUP_TIMEOUT=120
