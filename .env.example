TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# IBKR connection (defaults are for IB Gateway live trading).
# Uncomment and adjust as needed.
IBKR_HOST=127.0.0.1
IBKR_PORT=4001          # 4001=Gateway live, 4002=Gateway paper, 7496=TWS live, 7497=TWS paper
IBKR_CLIENT_ID=1

# IB Gateway / IBC settings (only used by -auto mode to start gateway).
# See README for IBC installation instructions.
IBC_PATH=/opt/ibc
IBC_INI=~/ibc/config.ini
TWS_PATH=~/Applications
TWS_MAJOR_VRSN=10.44
TRADING_MODE=paper       # 'live' or 'paper'
GATEWAY_STARTUP_TIMEOUT=120
